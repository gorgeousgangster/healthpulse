# JWT Configuration
HEALTHPULSE_JWT_SECRET_KEY=generate-a-secure-random-string-here
HEALTHPULSE_JWT_ALGORITHM=HS256
HEALTHPULSE_ACCESS_TOKEN_EXPIRE_MINUTES=60
HEALTHPULSE_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Railway provides DATABASE_URL automatically — see below)
HEALTHPULSE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthpulse

# CORS
HEALTHPULSE_ALLOWED_ORIGINS=["https://healthpulse.vercel.app","http://localhost:3000"]
